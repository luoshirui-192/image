# 生产环境配置模板（步骤 27）
# 用法：copy .env.production.example .env  后修改下列值

DEBUG=False
SECRET_KEY=请替换为随机长字符串
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.100

# 若通过 Nginx 以 HTTPS 对外，取消注释并填写实际域名
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
# SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# Database（生产必须使用 mysql）
DB_ENGINE=mysql
DB_HOST=192.168.1.154
DB_PORT=3306
DB_NAME=image_db
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8

# 可选：外部旧库（只读 BLOB 来源；路径表仍在 default 库）
# LEGACY_DB_HOST=192.168.1.200
# LEGACY_DB_PORT=3306
# LEGACY_DB_NAME=legacy_db
# LEGACY_DB_USER=readonly
# LEGACY_DB_PASSWORD=
# LEGACY_DB_CHARSET=utf8

# 前端访问地址（CORS）；Nginx 同域部署时填浏览器访问的 origin，例如 http://192.168.1.100
# 步骤 28 经 Nginx 反代后，前后端同域，仅需填一个地址
CORS_ALLOWED_ORIGINS=http://192.168.1.100

# Storage（留空则使用项目 upload/ 与 backend/thumb_cache/）
UPLOAD_ROOT=
THUMB_CACHE_ROOT=
MAX_UPLOAD_SIZE_MB=20
THUMB_SIZE=200

IMAGE_ACCESS_SECRET=请替换为独立随机密钥
IMAGE_ACCESS_TOKEN_TTL=3600

JWT_ACCESS_MINUTES=120
JWT_REFRESH_DAYS=7

SQL_QUERY_TIMEOUT=10
SQL_MAX_ROWS=1000
SQL_REQUIRE_WHERE_FOR_SELECT_STAR=false

DELETED_IMAGE_RETENTION_DAYS=30
LOG_RETENTION_DAYS=90
