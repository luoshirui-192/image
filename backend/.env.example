# Django
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: mysql | sqlite
DB_ENGINE=mysql
DB_HOST=192.168.1.154
DB_PORT=3306
DB_NAME=image_db
DB_USER=root
DB_PASSWORD=
# MySQL 5.1.x 使用 utf8；MySQL 5.5.3+ 可改为 utf8mb4
DB_CHARSET=utf8
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
UPLOAD_ROOT=
MAX_UPLOAD_SIZE_MB=20
THUMB_SIZE=200

# Image access token (Step 9)
IMAGE_ACCESS_SECRET=change-me-in-production
IMAGE_ACCESS_TOKEN_TTL=3600

# JWT
JWT_ACCESS_MINUTES=120
JWT_REFRESH_DAYS=7

# SQL query (Step 13)
SQL_QUERY_TIMEOUT=10
SQL_MAX_ROWS=1000
SQL_REQUIRE_WHERE_FOR_SELECT_STAR=false

# Maintenance (Step 16)
DELETED_IMAGE_RETENTION_DAYS=30
LOG_RETENTION_DAYS=90
