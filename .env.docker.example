# Docker 一键部署环境变量（复制为项目根目录 .env）
# cp .env.docker.example .env

# 浏览器访问地址（改成服务器 IP 或域名，不要末尾斜杠）
PUBLIC_URL=http://localhost

# 对外 HTTP 端口
HTTP_PORT=80

# MySQL（容器内自动建库，无需手工执行 sql/）
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_app
MYSQL_DATABASE=image_db
MYSQL_USER=image_db

# Django 密钥（务必修改；可用: python scripts/generate_secret_key.py）
SECRET_KEY=change-me-docker-secret-key
IMAGE_ACCESS_SECRET=change-me-docker-image-secret

# 定时维护（scheduler 容器）：操作日志保留、历史软删图片清理
LOG_RETENTION_DAYS=90
DELETED_IMAGE_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_HOURS=24
