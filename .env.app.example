# 机器 A 环境变量（复制为项目根目录 .env）
# cp .env.app.example .env

# ========== 本机（机器 A）==========
# 浏览器访问地址：填机器 A 的 IP 或域名，不要末尾斜杠
PUBLIC_URL=http://192.168.17.162

# 对外 HTTP 端口
HTTP_PORT=80

# ========== MySQL ==========
# 内置库（compose db 容器）：DB_HOST=db（默认）
# 宿主机已有库（如 mysql8039）：DB_HOST=host.docker.internal
DB_HOST=db
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_app
MYSQL_DATABASE=image_db
MYSQL_USER=image_db
# 与 MYSQL_PASSWORD 相同，或单独指定（external-db 时 backend 使用）
DB_PASSWORD=change_me_app

# 仅内置 db 容器映射 3306 时用；DB_HOST=host.docker.internal 时可忽略
MYSQL_PUBLISH_PORT=3306

# ========== 外部 MySQL（宿主机已有库，如 mysql8039）==========
# 设为 1 时 start-app.sh 会连 host.docker.internal:3306，不再启动 compose 内置 db 容器
# USE_EXTERNAL_MYSQL=1
# DB_PASSWORD 须与 MYSQL_USER 在宿主机 MySQL 中的密码一致（可与 MYSQL_PASSWORD 相同）
# DB_PASSWORD=change_me_app

# ========== 图片存储（MinIO — 由机器 B 对接 192.168.9.9）==========
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://192.168.9.9:9000
MINIO_ACCESS_KEY=your_minio_user
MINIO_SECRET_KEY=your_minio_password
MINIO_BUCKET=biox
MINIO_PREFIX=data/image_db
MINIO_SECURE=false

# 本地调试可改回 local，并使用 ./upload 目录：
# STORAGE_BACKEND=local

# ========== 安全密钥（生产务必修改）==========
# 生成：python3 scripts/generate_secret_key.py
SECRET_KEY=change-me-docker-secret-key
IMAGE_ACCESS_SECRET=change-me-docker-image-secret

# ========== 定时维护（scheduler 容器）==========
LOG_RETENTION_DAYS=90
DELETED_IMAGE_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_HOURS=24

# ========== Web 并发（约 4～5 人同时使用）==========
# sync worker：每人打开页面会打多个 API，6 较稳；大机器勿用 2*CPU+1（易打满 MySQL）
GUNICORN_WORKERS=6
GUNICORN_TIMEOUT=120
# GUNICORN_MAX_REQUESTS=800

# ========== BLOB 迁移性能（可选）==========
# 并行上传线程数；旧库 max_connections 较小时可改回 1，避免 Too many connections
BLOB_MIGRATION_UPLOAD_WORKERS=3
# BLOB_MIGRATION_BATCH_SIZE=100
# BLOB_MIGRATION_SKIP_DIMENSIONS=true

# ========== 外部 BLOB 自动同步 ==========
# BLOB_SYNC_ENABLED=true
# BLOB_SYNC_DEFAULT_INTERVAL_MINUTES=60
# BLOB_SYNC_BATCH_SIZE=200
# BLOB_SYNC_PURGE_OLD_IMAGE=true
# BLOB_SYNC_MAX_RESYNC_PER_RUN=50

# ALLOWED_HOSTS / CORS_ALLOWED_ORIGINS 由 start-app.sh 根据 PUBLIC_URL 自动写入
