# 机器 B 存储层环境变量（复制为项目根目录 .env）
# cp .env.storage.example .env
#
# 机器 B 职责：对接公司 MinIO 集群（VIP 192.168.9.9），
# 为 image_db 准备 biox 桶内的对象前缀与访问权限。
# 不在本机部署 MySQL / Django / NFS。

# ========== MinIO（亚略特 AI 存储 VIP）==========
MINIO_ENDPOINT=http://192.168.9.9:9000
MINIO_ACCESS_KEY=your_minio_user
MINIO_SECRET_KEY=your_minio_password
MINIO_BUCKET=biox
MINIO_PREFIX=data/image_db
MINIO_SECURE=false

# mc 别名（setup-minio-prefix.sh 使用，可选）
MINIO_MC_ALIAS=aratek

# ========== 机器 A（应用服务器，多个 IP 空格分隔）==========
# 用于文档/防火墙参考：MinIO 管理员需允许这些 IP 访问 9000
MACHINE_A_HOSTS=192.168.17.162
