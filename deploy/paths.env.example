# 步骤 28 — Nginx 部署路径（复制为 deploy/paths.env 后修改）
# 在目标服务器上填写实际路径；Linux 示例见下方默认值

# 项目根目录（含 backend/、frontend/、upload/）
PROJECT_ROOT=/opt/image_db

# 监听地址与端口
SERVER_NAME=192.168.1.100
LISTEN_PORT=80

# Django 后端（步骤 29 Gunicorn 监听；与 Nginx BACKEND_UPSTREAM 一致）
BACKEND_UPSTREAM=127.0.0.1:8000

# Gunicorn（步骤 29）
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Python 虚拟环境（服务器上 venv 路径，bin 下应有 gunicorn）
VENV_PATH=/opt/image_db/.venv

# systemd 运行用户（需对 upload/、backend/logs、backend/thumb_cache 可写）
RUN_USER=www-data
RUN_GROUP=www-data

# 是否对外直出 /upload/（0=关闭，推荐；1=开启会绕过 API 鉴权，仅内网慎用）
ENABLE_UPLOAD_DIRECT=0

# 上传大小上限（与 backend MAX_UPLOAD_SIZE_MB 一致或略大）
CLIENT_MAX_BODY_SIZE=25m

# 备份（步骤 30）
BACKUP_ROOT=/opt/image_db/backups
BACKUP_RETENTION_DAYS=14
