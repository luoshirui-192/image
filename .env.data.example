# 机器 B 数据层环境变量（复制为项目根目录 .env）
# cp .env.data.example .env

# ========== MySQL（Docker 或手工安装均使用这些名称）==========
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_app
MYSQL_DATABASE=image_db
MYSQL_USER=image_db

# Docker 对外暴露 MySQL 端口（供机器 A 连接）
MYSQL_PUBLISH_PORT=3306

# ========== 图片存储（宿主机路径，非容器内）==========
# 生产建议使用独立数据盘，例如 /data/image_db/upload
DATA_UPLOAD_ROOT=/data/image_db/upload

# ========== NFS（导出给机器 A）==========
# 机器 A 的 IP，用于授权 MySQL 与 NFS（多个 IP 用空格分隔）
MACHINE_A_HOSTS=192.168.1.10

# NFS 导出路径（通常与 DATA_UPLOAD_ROOT 相同）
NFS_EXPORT_PATH=/data/image_db/upload
